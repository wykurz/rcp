{
  // Markdown formatting for all docs: prose hard-wrapped at 100 columns.
  // Fix locally with `just fmt` (or `dprint fmt`); CI enforces via
  // scripts/check-doc-format.sh. Output is fully determined by the plugin
  // version + checksum pinned below (the dprint CLI version does not matter).
  // To upgrade the plugin run `dprint config update`.
  "lineWidth": 100,
  "markdown": {
    "textWrap": "always",
    "emphasisKind": "asterisks"
  },
  "excludes": [
    "**/target",
    "CLAUDE.md", // symlink to AGENTS.md
    "LICENSE.md", // canonical license text, keep verbatim
    "docs/superpowers" // gitignored session artifacts
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.22.1.wasm@4906fbb038977732aae0e216e4b0b957e2722f8d79282660ccb36d27dd051f17"
  ]
}
